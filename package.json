{
  "name": "@sero-ai/plugin-google",
  "version": "0.3.0",
  "description": "Google Workspace app for Sero — Gmail & Calendar with gogcli",
  "keywords": [
    "pi-package"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run --root . extension/__tests__", 
    "typecheck": "tsc --noEmit -p ui/tsconfig.json && tsc --noEmit -p extension/tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./extension/index.ts"
    ]
  },
  "sero": {
    "app": {
      "id": "google",
      "name": "Google",
      "icon": "mail",
      "scope": "global",
      "stateFile": ".sero/apps/google/state.json",
      "ui": "./dist/ui/remoteEntry.js",
      "component": "GoogleApp",
      "devPort": 5186
    },
    "widgets": [
      {
        "id": "mail-indicator",
        "name": "Mail",
        "component": "MailWidget",
        "description": "Unread count and recent inbox threads",
        "defaultSize": {
          "w": 2,
          "h": 2
        },
        "minSize": {
          "w": 2,
          "h": 2
        },
        "maxSize": {
          "w": 3,
          "h": 3
        }
      },
      {
        "id": "mini-calendar",
        "name": "Calendar",
        "component": "CalendarWidget",
        "description": "Month grid with event dots and upcoming events",
        "defaultSize": {
          "w": 2,
          "h": 3
        },
        "minSize": {
          "w": 2,
          "h": 2
        },
        "maxSize": {
          "w": 3,
          "h": 4
        }
      }
    ],
    "plugin": {
      "category": "integrations",
      "tags": [
        "google",
        "gmail",
        "calendar",
        "workspace"
      ],
      "minSeroVersion": "0.1.0",
      "preBuilt": false
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": ">=0.61.1",
    "@mariozechner/pi-coding-agent": ">=0.61.1",
    "@mariozechner/pi-tui": ">=0.61.1",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.11.0",
    "@sero-ai/app-runtime": "^0.1.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.4"
  }
}
